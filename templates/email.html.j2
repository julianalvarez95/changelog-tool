<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; background: #f5f5f5; margin: 0; padding: 20px; color: #333; }
  .container { max-width: 640px; margin: 0 auto; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
  .header { background: #1a1a2e; color: #fff; padding: 28px 32px; }
  .header h1 { margin: 0 0 4px; font-size: 22px; font-weight: 700; }
  .header .period { color: #a0aec0; font-size: 14px; }
  .summary { background: #f0f4ff; padding: 16px 32px; border-bottom: 1px solid #e2e8f0; }
  .summary p { margin: 0 0 10px; font-size: 13px; font-weight: 600; color: #4a5568; text-transform: uppercase; letter-spacing: 0.05em; }
  .summary-pills { display: flex; flex-wrap: wrap; gap: 8px; }
  .pill { background: #fff; border: 1px solid #cbd5e0; border-radius: 20px; padding: 4px 12px; font-size: 13px; color: #2d3748; white-space: nowrap; }
  .body { padding: 24px 32px; }
  .category { margin-bottom: 24px; }
  .category h2 { font-size: 15px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #1a1a2e; border-bottom: 2px solid #e2e8f0; padding-bottom: 6px; margin-bottom: 12px; }
  .commit-list { list-style: none; margin: 0; padding: 0; }
  .commit-list li { padding: 6px 0; font-size: 14px; line-height: 1.6; border-bottom: 1px solid #f0f0f0; color: #2d3748; }
  .commit-list li:last-child { border-bottom: none; }
  .repo-tag { display: inline-block; background: #edf2ff; color: #3b5bdb; font-size: 11px; font-weight: 600; padding: 1px 6px; border-radius: 3px; margin-left: 6px; }
  .domain-tag { display: inline-block; background: #f0fff4; color: #276749; font-size: 11px; font-weight: 600; padding: 1px 6px; border-radius: 3px; margin-left: 6px; }
  .breaking { display: inline-block; background: #fff0f0; color: #c0392b; font-size: 11px; font-weight: 700; padding: 1px 6px; border-radius: 3px; margin-left: 4px; }
  .intel-intro { background: #f0f4ff; padding: 14px 32px; border-bottom: 1px solid #e2e8f0; font-size: 14px; color: #4a5568; font-style: italic; }
  .footer { background: #f8f9fa; padding: 16px 32px; font-size: 12px; color: #718096; border-top: 1px solid #e2e8f0; }
  .no-changes { padding: 24px; text-align: center; color: #718096; font-size: 15px; }
  .empty-section { color: #a0aec0; font-style: italic; font-size: 13px; padding: 4px 0; }
  a { color: #3b5bdb; text-decoration: none; }
  a:hover { text-decoration: underline; }
</style>
</head>
<body>
<div class="container">
  <div class="header">
    <h1>{{ title }}</h1>
    <div class="period">{{ period }}</div>
  </div>
  {% if use_intelligence %}
  <div class="intel-intro">
    {{ intel_summary }}
  </div>
  <div class="body">
    <div class="category">
      <h2>🚀 Highlights</h2>
      {% if intelligence.highlights %}
      <ul class="commit-list">
        {% for item in intelligence.highlights %}
        <li>
          <strong>{{ item.title }}</strong> — {{ item.description }}
          <span class="domain-tag">{{ item.domain }}</span>
        </li>
        {% endfor %}
      </ul>
      {% else %}
      <p class="empty-section">Sin highlights esta semana.</p>
      {% endif %}
    </div>
    <div class="category">
      <h2>🐛 Correcciones</h2>
      {% if intelligence.fixes %}
      <ul class="commit-list">
        {% for item in intelligence.fixes %}
        <li>
          <strong>{{ item.title }}</strong> — {{ item.description }}
          <span class="domain-tag">{{ item.domain }}</span>
        </li>
        {% endfor %}
      </ul>
      {% else %}
      <p class="empty-section">Sin correcciones esta semana.</p>
      {% endif %}
    </div>
    <div class="category">
      <h2>⚡ Mejoras</h2>
      {% if intelligence.improvements %}
      <ul class="commit-list">
        {% for item in intelligence.improvements %}
        <li>
          <strong>{{ item.title }}</strong> — {{ item.description }}
          <span class="domain-tag">{{ item.domain }}</span>
        </li>
        {% endfor %}
      </ul>
      {% else %}
      <p class="empty-section">Sin mejoras internas esta semana.</p>
      {% endif %}
    </div>
  </div>
  {% elif has_changes %}
  {% if summary %}
  <div class="summary">
    <p>Esta semana</p>
    <div class="summary-pills">
      {% for item in summary %}
      <span class="pill">{{ item }}</span>
      {% endfor %}
    </div>
  </div>
  {% endif %}
  <div class="body">
    {% for cat in categories %}
    <div class="category">
      <h2>{{ cat.emoji }} {{ cat.label }}</h2>
      <ul class="commit-list">
        {% for c in cat.commits %}
        <li>
          {% if c.is_breaking %}<span class="breaking">BREAKING</span> {% endif %}
          {% if c.url %}<a href="{{ c.url }}">{{ c.description }}</a>{% else %}{{ c.description }}{% endif %}
          <span class="repo-tag">{{ c.repo_name }}</span>
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <div class="body">
    <div class="no-changes">No hubo cambios en este período.</div>
  </div>
  {% endif %}
  <div class="footer">
    Período: {{ period }} &nbsp;|&nbsp; {{ total_repos }} repo{% if total_repos != 1 %}s{% endif %} &nbsp;|&nbsp; {{ total_commits }} commit{% if total_commits != 1 %}s{% endif %}
  </div>
</div>
</body>
</html>
